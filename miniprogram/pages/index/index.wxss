.page { padding-bottom: 200px; }
.header { background: #ff6b35; color: #fff; padding: 16px; text-align: center; font-size: 18px; font-weight: bold; }
.section-title { padding: 12px 16px 4px; font-size: 14px; color: #888; }
.menu-item { margin: 8px 16px; padding: 10px; background: #fff; border-radius: 10px; display: flex; align-items: center; gap: 10px; }
.menu-img { width: 70px; height: 70px; border-radius: 8px; flex-shrink: 0; }
.menu-info { flex: 1; min-width: 0; }
.menu-name { font-size: 15px; font-weight: bold; margin-bottom: 4px; }
.menu-meta { font-size: 13px; color: #ff6b35; }
.menu-btn { background: #ff6b35; color: #fff; font-size: 13px; padding: 6px 14px; border-radius: 20px; }
.loading { text-align: center; padding: 30px; color: #aaa; }

.cart { position: fixed; bottom: 0; width: 100%; background: #fff; border-top: 1px solid #eee; padding: 12px 16px; box-sizing: border-box; }
.cart-title { font-size: 13px; color: #aaa; margin-bottom: 4px; }
.cart-empty { color: #ccc; font-size: 13px; }
.cart-row { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 2px; }
.cart-total { font-weight: bold; font-size: 16px; margin-top: 4px; padding-top: 8px; border-top: 1px solid #eee; }
.submit-btn { width: 100%; padding: 10px; background: #ff6b35; color: #fff; border-radius: 10px; font-size: 15px; font-weight: bold; margin-top: 8px; }
